{
  "name": "sic-network",
  "description": "Simple Irc Client network",
  "version": "1.1.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "start": "mkdir -p logs && tsx --env-file=.env ./server.ts 2>&1 | tee -a logs/$(date +%F).log",
    "dev": "tsx --env-file=.env ./server.ts",
    "pre-build": "tsc",
    "build": "node build.mjs",
    "lint": "tsc && pnpm exec eslint src/**/*.{ts,tsx}",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "ws": "^8.20.1"
  }
}
