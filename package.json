{
  "name": "sic-network",
  "description": "Simple Irc Client network",
  "version": "1.1.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "start": "mkdir -p logs && tsx --env-file=.env ./server.ts 2>&1 | tee -a logs/$(date +%F).log",
    "dev": "tsx --env-file=.env ./server.ts",
    "pre-build": "tsc",
    "build": "node build.mjs",
    "lint": "tsc && npx eslint src/**/*.{ts,tsx}",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
